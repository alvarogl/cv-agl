---
import '../styles/global.css';
const { locale, labels } = Astro.props;
const canonicalPath = locale === 'en' ? '/' : `/${locale}/`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{labels.meta.title}</title>
    <meta name="description" content={labels.meta.description} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="canonical" href={new URL(canonicalPath, Astro.site).toString()} />
  </head>
  <body>
    <slot />
  </body>
</html>
