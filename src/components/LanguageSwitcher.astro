---
const { locale, labels } = Astro.props;
const alternatePath = locale === 'en' ? '/es/' : '/';
---

<div class="language-switcher" aria-label={labels.language.label}>
  <span>{labels.language.label}</span>
  <a href="/" class:list={{ active: locale === 'en' }}>{labels.language.english}</a>
  <a href={alternatePath} class:list={{ active: locale === 'es' }}>{labels.language.spanish}</a>
</div>
